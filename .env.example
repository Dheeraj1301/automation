# Copy this file to .env and adjust as needed. No real secrets belong here.

ENV=local

# Postgres
POSTGRES_USER=profitpilot
POSTGRES_PASSWORD=profitpilot
POSTGRES_DB=profitpilot
DATABASE_URL=postgresql://profitpilot:profitpilot@localhost:5432/profitpilot

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Storefront - set this to the slug of the organization you want the
# storefront (http://localhost:3001) to serve. Create an org first via
# signup, then check its slug from the org switcher or GET /api/organizations.
STOREFRONT_MERCHANT_SLUG=

# AI Sales Agent (Phase 7) - requires your own Anthropic API key, get one at
# https://console.anthropic.com/. Never paste it into chat; set it here in
# your local, git-ignored .env only. Without it the AI chat endpoint returns
# a clear 503 - everything else in the app still works.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Zoho CRM (Phase 9) - each merchant connects their own Zoho account from
# Dashboard > Settings > Integrations; nothing here is a shared credential
# used on their behalf. To enable the "Connect Zoho CRM" button at all, you
# (the platform operator) register one free OAuth client:
#   1. https://api-console.zoho.com/ -> Add Client -> Server-based
#      Applications.
#   2. Homepage URL: http://localhost:3000 (or your prod app domain).
#   3. Authorized Redirect URI: must exactly match ZOHO_REDIRECT_URI below.
#   4. Copy the generated Client ID/Secret here.
# Leave both blank to leave CRM sync mocked (logged, never sent) - nothing
# else in the app is affected either way.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:8000/api/integrations/zoho/callback

# Encrypts Zoho's OAuth tokens at rest. Optional locally (derived from
# JWT_SECRET if unset) - see .env.production.example for why prod requires
# its own explicit key.
TOKEN_ENCRYPTION_KEY=
