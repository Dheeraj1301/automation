# Copy to .env.production on the VPS and fill in every value. Unlike
# .env.example (local dev), there are no working defaults here on purpose -
# production must not run on dev secrets. Never commit the filled-in file.

# Your domain, no protocol/subdomain (e.g. profitpilot.com). nginx and the
# app containers derive app./api./automation. subdomains from this.
DOMAIN=

# Email Let's Encrypt uses for expiry/urgent renewal notices.
LETSENCRYPT_EMAIL=

# Postgres - pick a strong password, this is the only durable data store.
POSTGRES_USER=profitpilot
POSTGRES_PASSWORD=
POSTGRES_DB=profitpilot

# Auth - generate with: openssl rand -hex 32
JWT_SECRET=

# Storefront - slug of the organization the public storefront serves.
# Same meaning as in .env.example; leave blank until you've created the org.
STOREFRONT_MERCHANT_SLUG=

# AI Sales Agent (Phase 7) - https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# n8n (Phase 8/9)
# Encryption key for n8n's stored credentials - generate with:
#   openssl rand -hex 32
# and back it up somewhere safe. If this is lost or changed, n8n can no
# longer decrypt any credentials already saved in its database/volume.
N8N_ENCRYPTION_KEY=
# Basic auth in front of the n8n editor UI (this does NOT protect the
# /webhook/* endpoints - those must stay reachable for lead capture to work,
# and n8n does not gate them behind basic auth by design).
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Zoho CRM (Phase 9) - each merchant connects their own Zoho account from
# Dashboard > Settings > Integrations. Register the platform's OAuth client
# at https://api-console.zoho.com/ (Server-based Application). Its redirect
# URI is derived from DOMAIN above (docker-compose.prod.yml sets it to
# https://api.<DOMAIN>/api/integrations/zoho/callback automatically) - use
# that exact URL when registering the client in Zoho's console.
# Leave both blank to leave CRM sync mocked (logged, never sent).
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Encrypts Zoho's OAuth tokens at rest - generate with:
#   openssl rand -base64 32 | cut -c1-32 | base64
# or in Python: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Back this up somewhere safe (e.g. alongside N8N_ENCRYPTION_KEY) - if it's
# lost or changed, every merchant's stored Zoho connection breaks and they
# have to reconnect.
TOKEN_ENCRYPTION_KEY=
